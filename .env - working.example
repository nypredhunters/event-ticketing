# Default event slug (matches the 'slug' column in your DB)
DEFAULT_EVENT_SLUG=my-event

# Supabase (Project settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-side only, keep secret

# PayPal (developer.paypal.com > Apps & Credentials)
PAYPAL_ENV=sandbox                 # 'sandbox' for testing, 'live' when ready
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET

# Resend email (resend.com > API Keys). FROM must be a verified domain/sender.
RESEND_API_KEY=YOUR_RESEND_KEY
EMAIL_FROM=Tickets <tickets@yourdomain.com>

# Admin/door-scanner password — make this long and random
ADMIN_TOKEN=CHANGE_ME_to_a_long_random_string
